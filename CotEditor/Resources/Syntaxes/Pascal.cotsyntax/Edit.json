{
  "comment" : {
    "blocks" : [
      {
        "begin" : "{",
        "end" : "}"
      },
      {
        "begin" : "(*",
        "end" : "*)"
      }
    ],
    "inlines" : [
      {
        "begin" : "//"
      }
    ]
  },
  "stringDelimiters" : [
    {
      "begin" : "'",
      "end" : "'",
      "escapeCharacter" : "'"
    }
  ],
  "indentation" : {
    "blockDelimiters" : [
      {
        "begin" : "begin",
        "end" : "end",
        "ignoreCase" : true
      },
      {
        "begin" : "repeat",
        "end" : "until",
        "ignoreCase" : true
      }
    ]
  }
}