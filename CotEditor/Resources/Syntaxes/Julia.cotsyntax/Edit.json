{
  "characterDelimiters" : [
    {
      "begin" : "'",
      "end" : "'",
      "escapeCharacter" : "\\"
    }
  ],
  "comment" : {
    "blocks" : [
      {
        "begin" : "#=",
        "end" : "=#",
        "isNestable" : true
      }
    ],
    "inlines" : [
      {
        "begin" : "#"
      }
    ]
  },
  "indentation" : {
    "blockDelimiters" : [
      {
        "begin" : "begin",
        "end" : "end"
      },
      {
        "begin" : "try",
        "end" : "end"
      }
    ]
  },
  "stringDelimiters" : [
    {
      "begin" : "\"",
      "end" : "\"",
      "escapeCharacter" : "\\",
      "isMultiline" : true
    },
    {
      "begin" : "\"\"\"",
      "end" : "\"\"\"",
      "escapeCharacter" : "\\",
      "isMultiline" : true
    },
    {
      "begin" : "\"",
      "description" : "Prefixed string literal",
      "end" : "\"",
      "escapeCharacter" : "\\",
      "prefixes" : [
        "b",
        "r",
        "v"
      ]
    }
  ]
}