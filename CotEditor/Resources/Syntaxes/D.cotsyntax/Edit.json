{
  "comment" : {
    "blocks" : [
      {
        "begin" : "/*",
        "end" : "*/"
      },
      {
        "begin" : "/+",
        "end" : "+/",
        "isNestable" : true
      }
    ],
    "inlines" : [
      {
        "begin" : "//"
      }
    ]
  },
  "stringDelimiters" : [
    {
      "begin" : "\"",
      "end" : "\"",
      "isMultiline" : true,
      "escapeCharacter" : "\\"
    },
    {
      "begin" : "`",
      "end" : "`",
      "isMultiline" : true,
      "description" : "WYSIWYG string literal"
    },
    {
      "begin" : "q{",
      "end" : "}",
      "isMultiline" : true,
      "description" : "Token string literal with { } delimiter"
    },
    {
      "begin" : "r\"",
      "end" : "\"",
      "isMultiline" : true,
      "description" : "WYSIWYG string literal with r-prefix"
    },
    {
      "begin" : "x\"",
      "end" : "\"",
      "isMultiline" : true,
      "description" : "Hex string literal"
    }
  ],
  "characterDelimiters" : [
    {
      "begin" : "'",
      "end" : "'",
      "escapeCharacter" : "\\"
    }
  ],
  "indentation" : {
    "blockDelimiters" : [
      {
        "begin" : "{",
        "end" : "}"
      }
    ]
  }
}