{
  "comment" : {
    "blocks" : [
      {
        "begin" : "/*",
        "end" : "*/"
      },
      {
        "begin" : "/+",
        "end" : "+/",
        "isNestable" : true
      }
    ],
    "inlines" : [
      {
        "begin" : "//"
      }
    ]
  },
  "stringDelimiters" : [
    {
      "begin" : "\"",
      "end" : "\"",
      "isMultiline" : true
    },
    {
      "begin" : "`",
      "end" : "`",
      "isMultiline" : true,
      "escapeRule" : "none"
    },
    {
      "begin" : "q{",
      "end" : "}",
      "isMultiline" : true,
      "escapeRule" : "none"
    },
    {
      "begin" : "r\"",
      "end" : "\"",
      "isMultiline" : true,
      "escapeRule" : "none"
    },
    {
      "begin" : "x\"",
      "end" : "\"",
      "isMultiline" : true,
      "escapeRule" : "none"
    }
  ],
  "indentation" : {
    "blockDelimiters" : [
      {
        "begin" : "{",
        "end" : "}"
      }
    ]
  }
}