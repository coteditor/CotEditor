{
  "comment" : {
    "blocks" : [
      {
        "begin" : "=begin",
        "end" : "=end"
      }
    ],
    "inlines" : [
      {
        "begin" : "#"
      }
    ]
  },
  "indentation" : {
    "blockDelimiters" : [
      {
        "begin" : "{",
        "end" : "}"
      },
      {
        "begin" : "begin",
        "end" : "end"
      },
      {
        "begin" : "then",
        "end" : "end"
      }
    ]
  },
  "stringDelimiters" : [
    {
      "begin" : "\"",
      "end" : "\"",
      "escapeCharacter" : "\\"
    },
    {
      "begin" : "'",
      "end" : "'",
      "escapeCharacter" : "\\"
    },
    {
      "begin" : "`",
      "end" : "`",
      "escapeCharacter" : "\\"
    }
  ]
}