      "end" : "\"",
      "escapeCharacter" : "\\",
      "prefixes" : [
        "L",
        "u8",
        "u",
        "U"
      ]
    },
    {
      "begin" : "\"",
      "description" : "Raw string literal (simplified delimiter handling)",
      "end" : "\"",
      "isMultiline" : true,
      "prefixes" : [
        "R",
        "LR",
        "u8R",
        "uR",
        "UR"
