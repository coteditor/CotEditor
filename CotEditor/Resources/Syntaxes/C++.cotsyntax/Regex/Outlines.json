[
  {
    "description" : "constructor",
    "kind" : "function",
    "pattern" : "^([\\t ]*)(\\w+::\\w+)\\s*\\(([\\s\\w*&,\\[\\]]*)\\)",
    "template" : "$1$2($3)"
  },
  {
    "description" : "deconstructor",
    "kind" : "function",
    "pattern" : "^([\\t ]*)(\\w+::~\\w+)\\s*\\(\\)",
    "template" : "$1$2()"
  },
  {
    "description" : "function",
    "kind" : "function",
    "pattern" : "^([\\t ]*)(\\w[\\w\\s]*)\\s+(\\**\\w+)\\(([\\s\\w*&,\\[\\]]*)\\)[\\t ]*(?=\\{|//|$)",
    "template" : "$1 $3($4)"
  },
  {
    "description" : "method",
    "kind" : "function",
    "pattern" : "^([\\t ]*)(\\w[\\w\\s]*)\\s+(\\**\\w+::\\w+)\\(([\\s\\w*&,]*)\\)[\\t ]*(?=\\{|//|$)",
    "template" : "$1 $3($4)"
  },
  {
    "description" : "class",
    "kind" : "container",
    "pattern" : "^class[\\t ]+(\\w+)",
    "template" : "$1"
  },
  {
    "description" : "enum",
    "kind" : "container",
    "pattern" : "^enum[\\t ]+(\\w+)",
    "template" : "enum $1"
  },
  {
    "description" : "struct",
    "kind" : "container",
    "pattern" : "^struct[\\t ]+(\\w+)",
    "template" : "struct $1"
  },
  {
    "description" : "union",
    "kind" : "container",
    "pattern" : "^union[\\t ]+(\\w+)",
    "template" : "union $1"
  }
]