    "NewFeature.syntax.description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "По-точно подчертаване, по-интелигентно коментиране и подобрено поведение на отстъпа — задвижвани от преработен механизъм за синтаксис и формат на дефиниция."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Genauere Hervorhebung, intelligentere Kommentierung und verbessertes Einrückungsverhalten – ermöglicht durch eine überarbeitete Syntax-Engine und ein neues Definitionsformat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "More accurate highlighting, smarter commenting, and improved indentation behavior — powered by a redesigned syntax engine and definition format."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "More accurate highlighting, smarter commenting, and improved indentation behaviour — powered by a redesigned syntax engine and definition format."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Resaltado más preciso, comentarios más inteligentes y mejor comportamiento de sangría, impulsados por un motor de sintaxis y un formato de definición rediseñados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Une coloration plus précise, des commentaires plus intelligents et un comportement d'indentation amélioré, grâce à un moteur de syntaxe et un format de définition repensés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "刷新されたシンタックスエンジンと定義フォーマットにより、より正確なハイライト、よりスマートなコメント機能、そして改善されたインデント動作を実現しました。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Nauwkeurigere accentuering, slimmer commentaar en verbeterd inspringgedrag, mogelijk gemaakt door een vernieuwde syntaxisengine en definitie-indeling."
          }
        }
      }
    },
