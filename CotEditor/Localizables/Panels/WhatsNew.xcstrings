    "NewFeature.treeSitter.description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Много от основните вградени синтаксиси вече използват tree-sitter — модерен анализатор, базиран на структура — за по-дълбоко и по-надеждно разбиране на езика."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Viele wichtige integrierte Syntaxen verwenden jetzt tree-sitter – einen modernen, strukturbasierten Parser – für tiefere und zuverlässigere Spracherkennung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Many major built-in syntaxes now use tree-sitter — a modern, structure-based parser — enabling deeper and more reliable language awareness."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Many major built-in syntaxes now use tree-sitter — a modern, structure-based parser — enabling deeper and more reliable language awareness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Muchas de las principales sintaxis integradas ahora utilizan tree-sitter — un analizador moderno basado en la estructura — lo que permite un reconocimiento del lenguaje más profundo y fiable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "De nombreuses syntaxes intégrées majeures utilisent désormais tree-sitter — un analyseur moderne basé sur la structure — permettant une reconnaissance du langage plus profonde et plus fiable."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "主要な組み込みシンタックスが、構造ベースのモダンなパーサであるtree-sitterを採用。より深く確かな言語認識を可能にします。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Veel belangrijke ingebouwde syntaxisdefinities gebruiken nu tree-sitter — een moderne, op structuur gebaseerde parser — voor diepere en betrouwbaardere taalherkenning."
          }
        }
      }
    },
