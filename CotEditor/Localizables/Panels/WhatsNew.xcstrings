    "NewFeature.outline.description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Иконите улесняват прегледа на структурата, а синтаксисите с tree-sitter вече поддържат сгъваеми нива според йерархията."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Symbole erleichtern das Erfassen der Struktur, und tree-sitter-basierte Syntaxen unterstützen jetzt einklappbare Gliederungen, die die Hierarchie widerspiegeln."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Icons make structure easier to scan, and tree-sitter–based syntaxes now support collapsible outlines that reflect hierarchy."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Icons make structure easier to scan, and tree-sitter–based syntaxes now support collapsible outlines that reflect hierarchy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Los iconos facilitan la lectura de la estructura, y las sintaxis basadas en tree-sitter ahora admiten esquemas plegables que reflejan la jerarquía."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Les icônes facilitent la lecture de la structure, et les syntaxes basées sur tree-sitter prennent désormais en charge les plans repliables reflétant la hiérarchie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイコンが構造の把握を容易にし、tree-sitterベースのシンタックスでは階層を反映した折りたたみ可能なアウトラインをサポートします。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Symbolen maken de structuur overzichtelijker, en op tree-sitter gebaseerde syntaxisdefinities ondersteunen nu inklapbare overzichten die de hiërarchie weerspiegelen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simgeler, yapıyı taramayı kolaylaştırır ve tree-sitter tabanlı sözdizimler artık hiyerarşiyi yansıtan daraltılabilir ana hatları destekler."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "图标让结构更易浏览，基于tree-sitter的语法现已支持可折叠且反映层级的大纲。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "圖示讓結構更容易掃描，而且基於tree-sitter的語法現在支援可收合的大綱，能反映階層。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "圖示使結構更易掃描；基於tree-sitter的語法現已支援可摺疊大綱，可呈現代碼階層。"
          }
        }
      }
    },
