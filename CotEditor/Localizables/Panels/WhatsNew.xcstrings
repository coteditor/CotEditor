    "NewFeature.customIndentStyle.description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passe nach Belieben den Einzugsstil für einzelne Syntaxen in den Einstellungen „Modus“ an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Use Mode settings to customize the indentation style for individual syntaxes as you like."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Mode settings to customize the indentation style for individual syntaxes as you like."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Usa los ajustes de Modo para personalizar el estilo de sangría de sintaxis concretas a tu gusto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Utilisez les réglages Mode pour personnaliser le style d’indentation de certaines syntaxes à votre convenance."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "お好みで、「モード」設定でシンタックスごとにインデントスタイルをカスタマイズできるようになりました。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Pas de inspringstijl naar wens per syntaxis aan in de Modusinstellingen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mod ayarlarını kullanarak, istediğiniz gibi her bir sözdizimi için girintileme stilini özelleştirebilirsiniz."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用“模式”设置，按需为各个语法自定义缩进样式。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用模式設定，依您的喜好為個別語法自訂縮排樣式。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用「模式設定」按需要自訂個別語法的縮排樣式。"
          }
        }
      }
    },
