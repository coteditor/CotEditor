    "NewFeature.documentName.description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unter macOS 27 erhalten unbenannte Dokumente automatisch einen aus ihrem Inhalt vorgeschlagenen Arbeitsnamen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "On macOS 27, untitled documents automatically get a draft name suggested from their content."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On macOS 27, untitled documents automatically get a draft name suggested from their content."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "En macOS 27, los documentos sin título reciben automáticamente un nombre provisional sugerido a partir de su contenido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sous macOS 27, les documents sans titre reçoivent automatiquement un nom provisoire suggéré à partir de leur contenu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "macOS 27では、名称未設定の書類に内容から提案された書類名の草案が自動で付くようになりました。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "In macOS 27 krijgen naamloze documenten automatisch een conceptnaam op basis van hun inhoud."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "macOS 27 ile, başlıksız belgeler kendiliğinden içeriklerinden önerilen bir taslak adı alır."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 macOS 27 中，系统会根据内容为未命名文稿自动建议一个草稿名称。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在macOS 27上，未命名文件會自動根據內容獲得建議的草稿名稱。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在macOS 27上，未命名的文件會自動從其內容中建議一個草稿名稱。"
          }
        }
      }
    },
