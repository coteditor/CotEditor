    "NewFeature.syntax.description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "По-точно подчертаване, по-интелигентно коментиране и подобрено поведение на редактора, задвижвани от преработен механизъм за синтаксис и формат на дефиниция."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Genauere Hervorhebung, intelligentere Kommentierung und verbessertes Editorverhalten, alles ermöglicht durch eine überarbeitete Syntax-Engine und ein neues Definitionsformat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "More accurate highlighting, smarter commenting, and improved editor behavior, all powered by a redesigned syntax engine and definition format."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "More accurate highlighting, smarter commenting, and improved editor behaviour, all powered by a redesigned syntax engine and definition format."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Resaltado más preciso, comentarios más inteligentes y mejor comportamiento del editor, todo ello gracias a un motor de sintaxis y un formato de definición rediseñados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Une coloration plus précise, des commentaires plus intelligents et un meilleur comportement de l'éditeur, le tout grâce à un moteur de syntaxe et un format de définition repensés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "刷新されたシンタックスエンジンと定義フォーマットにより、より正確なハイライト、よりスマートなコメント機能、そして改善されたエディタの動作を実現しました。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Nauwkeurigere accentuering, slimmer commentaar en verbeterd editorgedrag, mogelijk gemaakt door een vernieuwde syntaxisengine en definitie-indeling."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Daha doğru vurgulama, daha akıllı yoruma çevirme ve iyileştirilmiş düzenleyici davranışı; hepsi yeniden tasarlanmış bir sözdizim işletkesi ve tanım biçimleri sayesinde olanaklı kılındı."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "借助重新设计的语法引擎和定义格式，高亮更准确，注释更智能，编辑器行为也得到改进。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更準確的醒目顯示、更智慧的註解，以及改善的編輯器行為，全由重新設計的語法引擎與定義格式提供支援。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "透過重新設計的語法引擎與定義格式，提供更準確的重點標示、更智能的註解功能，以及更流暢的編輯器反應。"
          }
        }
      }
    },
