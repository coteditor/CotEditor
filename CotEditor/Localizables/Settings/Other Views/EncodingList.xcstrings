{
  "sourceLanguage" : "en",
  "strings" : {
    "Drag encodings to change the order:" : {
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Плъзнете кодировките, за да промените реда:"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pořadí kódování změníte přetažením:"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ziehe die Codierungen, um die Reihenfolge zu ändern:"
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drag encodings to change the order:"
          }
        },
        "es" : {
