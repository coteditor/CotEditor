            "state" : "translated",
            "value" : "Faites glisser les encodages pour changer l’ordre :"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascinare le codifiche per modificarne l’ordine:"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "エンコーディングをドラッグして並び替えてください:"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "인코딩을 드래그하여 순서 변경:"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sleep coderingen om de volgorde te wijzigen:"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przeciągnij kodowania, aby zmienić kolejność:"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arraste codificações para alterar a ordem:"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
