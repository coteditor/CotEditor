          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sıralamayı değiştirmek için kodlamaları sürükleyin:"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拖拽以改变编码顺序："
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拖拽以改變編碼順序："
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拖移編碼以更改次序："
          }
        }
      }
    },
    "EncodingListView.Model.RemovalError.defaultEncoding.description" : {
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кодирането, зададено по подразбиране, не може да бъде премахнато."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kódování nastavené jako výchozí nelze odstranit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die als Standard festgelegte Codierung kann nicht entfernt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The encoding set as default can’t be removed."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The encoding set as default can’t be removed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La codificación establecida por defecto no puede eliminarse."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "L’encodage défini par défaut ne peut pas être supprimé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La codifica impostata come predefinita non può essere rimossa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デフォルトに設定されているエンコーディングは削除できません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기본 인코딩으로 설정된 항목은 삭제할 수 없습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "De standaard ingestelde codering kan niet worden verwijderd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kodowanie ustawione jako domyślne nie może zostać usunięte."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O conjunto de codificação definido como padrão não pode ser removido."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кодировку, установленную по умолчанию, удалить невозможно."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saptanmış olarak ayarlanan kodlama kaldırılamaz."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "设置为默认的编码无法被移除。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定為預設的編碼無法被移除。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法移除設定為預設的編碼。"
          }
        }
      }
    },
